<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/glass_card_bg"
    android:orientation="vertical"
    android:padding="28dp">

    <!-- 顶部图标 + 标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_time_capsule"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="封存时间胶囊"
            android:textColor="?attr/themeTextPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="选择胶囊开启日期，届时之前内容将被安全封存。"
        android:textColor="?attr/themeTextSecondary"
        android:textSize="13sp"
        android:lineSpacingExtra="3dp"
        android:layout_marginBottom="20dp"/>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/themeSeparator"
        android:layout_marginBottom="16dp" />

    <DatePicker
        android:id="@+id/date_picker_capsule"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:calendarViewShown="false"
        android:datePickerMode="spinner"
        android:layout_marginBottom="16dp"/>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/themeSeparator"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_capsule_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="取消"
            android:background="@drawable/capsule_btn_cancel_bg"
            android:textColor="?attr/themeTextSecondary"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btn_capsule_confirm"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="立即封存"
            android:background="@drawable/capsule_btn_confirm_bg"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="15sp" />
    </LinearLayout>
</LinearLayout>
