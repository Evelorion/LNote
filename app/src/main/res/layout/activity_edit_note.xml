<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/edit_header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
                app:tint="?attr/themeTextPrimary"
            android:scaleType="centerInside" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_saved_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● 已加密保存"
                android:textColor="@color/ios_green"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/pill_badge_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_more"
            app:tint="?attr/themeTextPrimary"
            android:scaleType="centerInside" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/edit_header"
        android:layout_above="@+id/bottom_toolbar_container"
        android:fillViewport="true">

        <FrameLayout
            android:id="@+id/editor_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_edit_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="编辑中..."
                    android:textColor="?attr/themeTextTertiary"
                    android:textSize="12sp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="15dp" />

                <EditText
                    android:id="@+id/et_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="标题"
                    android:textColor="?attr/themeTextPrimary"
                    android:textColorHint="?attr/themeTextPlaceholder"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:inputType="textMultiLine"
                    android:layout_marginBottom="20dp" />

                <EditText
                    android:id="@+id/et_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="开始输入..."
                    android:textColor="?attr/themeTextSecondary"
                    android:textColorHint="?attr/themeTextPlaceholder"
                    android:textSize="17sp"
                    android:lineSpacingExtra="6dp"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:minHeight="400dp" />

                <Spinner
                    android:id="@+id/spinner_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- 图片贴纸容器 -->
            <FrameLayout
                android:id="@+id/sticker_container"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>
    </ScrollView>

    <!-- Floating Bottom Toolbar -->
    <LinearLayout
        android:id="@+id/bottom_toolbar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="20dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:background="@drawable/glass_toolbar_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="6dp"
            android:elevation="12dp">

            <ImageButton
                android:id="@+id/btn_bold"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_margin="2dp"
                android:background="@drawable/glass_button_bg"
                android:src="@drawable/ic_edit"
                android:contentDescription="加粗"
                android:scaleType="centerInside"
                android:padding="9dp"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btn_italic_text"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_margin="2dp"
                android:background="@drawable/glass_button_bg"
                android:src="@android:drawable/ic_menu_edit"
                android:contentDescription="斜体"
                android:scaleType="centerInside"
                android:padding="9dp"
                app:tint="@color/white" />

            <ImageButton
                android:id="@+id/btn_image"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_margin="2dp"
                android:background="@drawable/glass_button_bg"
                android:src="@drawable/ic_gallery"
                android:contentDescription="插入图片"
                android:scaleType="centerInside"
                android:padding="9dp"
                app:tint="@color/white" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@drawable/glass_separator"
                android:layout_marginHorizontal="4dp" />

            <ImageButton
                android:id="@+id/btn_time_capsule"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_margin="2dp"
                android:background="@drawable/glass_button_bg"
                android:src="@drawable/ic_time_capsule"
                android:contentDescription="时间胶囊"
                android:scaleType="centerInside"
                android:padding="9dp"
                app:tint="@color/accent_blue" />

            <ImageButton
                android:id="@+id/btn_list"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_margin="2dp"
                android:background="@drawable/glass_button_bg"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:contentDescription="列表"
                android:scaleType="centerInside"
                android:padding="9dp"
                app:tint="#B0FFFFFF" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="@drawable/glass_separator"
                android:layout_marginHorizontal="6dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_save"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="完成"
                android:textAllCaps="false"
                android:background="@drawable/glass_save_button_bg"
                android:textColor="@color/white"
                android:paddingHorizontal="18dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="4dp" />

        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
