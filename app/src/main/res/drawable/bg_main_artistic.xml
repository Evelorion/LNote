<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 基础背景色 -->
    <item>
        <shape>
            <solid android:color="@color/bg_dark_blue" />
        </shape>
    </item>

    <!-- 右上角艺术图案 (树叶/花卉) -->
    <item
        android:gravity="top|end"
        android:top="-40dp"
        android:right="-40dp">
        <rotate
            android:fromDegrees="-15"
            android:pivotX="50%"
            android:pivotY="50%">
            <vector
                android:width="200dp"
                android:height="200dp"
                android:viewportWidth="24"
                android:viewportHeight="24">
                <path
                    android:fillColor="#15FFFFFF"
                    android:pathData="M12,2C12,2 14,6 18,7C14,8 12,12 12,12C12,12 10,8 6,7C10,6 12,2 12,2Z" />
                <path
                    android:fillColor="#10FFFFFF"
                    android:pathData="M12,22C12,22 10,18 6,17C10,16 12,12 12,12C12,12 14,16 18,17C14,18 12,22 12,22Z" />
            </vector>
        </rotate>
    </item>

    <!-- 左下角花朵 -->
    <item
        android:gravity="bottom|start"
        android:bottom="-30dp"
        android:left="-30dp">
        <vector
            android:width="150dp"
            android:height="150dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:fillColor="#0AFFFFFF"
                android:pathData="M12,12m-3,0a3,3 0,1 1,6 0a3,3 0,1 1,-6 0" />
            <path
                android:fillColor="#08FFFFFF"
                android:pathData="M12,9c0,-2 2,-4 4,-4c2,0 4,2 4,4c0,2 -2,4 -4,4M12,15c0,2 -2,4 -4,4c-2,0 -4,-2 -4,-4c0,-2 2,-4 4,-4M15,12c2,0 4,2 4,4c0,2 -2,4 -4,4c-2,0 -4,-2 -4,-4M9,12c-2,0 -4,-2 -4,-4c0,-2 2,-4 4,-4c2,0 4,2 4,4" />
        </vector>
    </item>

</layer-list>
