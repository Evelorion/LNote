<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- iOS风格主题 - 默认/白天模式 -->
    <style name="Theme.NoteApp" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- iOS风格颜色 - 白天 -->
        <item name="colorPrimary">@color/ios_blue</item>
        <item name="colorPrimaryVariant">@color/ios_blue</item>
        <item name="colorSecondary">@color/ios_cyan</item>
        <item name="colorSecondaryVariant">@color/ios_green</item>
        <item name="colorError">@color/ios_red</item>
        <item name="colorSurface">@color/bg_card_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        
        <!-- 背景颜色 -->
        <item name="android:windowBackground">@color/bg_light_blue</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:statusBarColor">@color/bg_light_blue</item>
        <item name="android:navigationBarColor">@color/bg_card_light</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- 自定义主题属性 - 白天模式 -->
        <item name="themeBgPrimary">@color/bg_light_blue</item>
        <item name="themeBgCard">@color/bg_card_light</item>
        <item name="themeBgSearch">@color/bg_search_light</item>
        <item name="themeTextPrimary">@color/light_text_primary</item>
        <item name="themeTextSecondary">@color/light_text_secondary</item>
        <item name="themeTextTertiary">@color/light_text_tertiary</item>
        <item name="themeTextPlaceholder">@color/light_text_placeholder</item>
        <item name="themeSeparator">@color/light_separator</item>
        <item name="themeNavBg">@color/light_nav_bg</item>
        <item name="themeToolbarBg">@color/bg_card_light</item>
        <item name="themeCardMint">@color/light_card_mint</item>
        <item name="themeCardCream">@color/light_card_cream</item>
        <item name="themeCardBlue">@color/light_card_blue</item>
        <item name="themeCardLavender">@color/light_card_lavender</item>
    </style>
    
    <!-- 护眼模式主题 -->
    <style name="Theme.NoteApp.EyeCare" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/ios_blue</item>
        <item name="colorPrimaryVariant">@color/ios_blue</item>
        <item name="colorSecondary">@color/ios_cyan</item>
        <item name="colorSecondaryVariant">@color/ios_green</item>
        <item name="colorError">@color/ios_red</item>
        <item name="colorSurface">@color/bg_card_eye_care</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOnSurface">@color/eye_care_text_primary</item>

        <item name="android:windowBackground">@color/bg_eye_care</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:statusBarColor">@color/bg_eye_care</item>
        <item name="android:navigationBarColor">@color/eye_care_nav_bg</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- 自定义主题属性 - 护眼模式 -->
        <item name="themeBgPrimary">@color/bg_eye_care</item>
        <item name="themeBgCard">@color/bg_card_eye_care</item>
        <item name="themeBgSearch">@color/bg_search_eye_care</item>
        <item name="themeTextPrimary">@color/eye_care_text_primary</item>
        <item name="themeTextSecondary">@color/eye_care_text_secondary</item>
        <item name="themeTextTertiary">@color/eye_care_text_tertiary</item>
        <item name="themeTextPlaceholder">@color/eye_care_text_placeholder</item>
        <item name="themeSeparator">@color/eye_care_separator</item>
        <item name="themeNavBg">@color/eye_care_nav_bg</item>
        <item name="themeToolbarBg">@color/bg_card_eye_care</item>
        <item name="themeCardMint">@color/eye_care_card_mint</item>
        <item name="themeCardCream">@color/eye_care_card_cream</item>
        <item name="themeCardBlue">@color/eye_care_card_blue</item>
        <item name="themeCardLavender">@color/eye_care_card_lavender</item>
    </style>

    <!-- iOS风格的卡片容器样式 -->
    <style name="GlassCardStyle" parent="">
        <item name="android:background">@drawable/glass_bg_shape</item>
        <item name="android:elevation">8dp</item>
    </style>
    
    <!-- iOS风格按钮样式 -->
    <style name="IOSButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="backgroundColor">@color/ios_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="elevation">0dp</item>
    </style>
    
    <!-- iOS风格编辑文本 -->
    <style name="IOSEditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/glass_bg_shape</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorHint">@color/ios_text_placeholder</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">12dp</item>
    </style>

</resources>
